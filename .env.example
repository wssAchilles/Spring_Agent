# qKnow 环境变量模板
# 复制为 .env 并填入真实值

# DeepSeek API（Agent 对话、查询重写、质量评分）
HERMES_OPENAI_API_KEY=sk-your-deepseek-key
HERMES_OPENAI_BASE_URL=https://api.deepseek.com

# 通义千问 API（Embedding 向量化）
TONGYI_API_KEY=sk-your-tongyi-key

# OpenAI API（备用）
OPENAI_API_KEY=sk-your-openai-key

# GitHub PAT（MCP 工具可选）
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your-github-token

# PostgreSQL
POSTGRESQL_USERNAME=postgres
POSTGRESQL_PASSWORD=postgres

# Redis
REDIS_PASSWORD=

# RAG 查询增强
HERMES_RAG_QUERY_TRANSFORM_ENABLED=false

# RSA 密钥（Base64 编码，不含 PEM 头尾）
# 生成命令：
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | grep -v "-----" | tr -d '\n'
#   cat public.pem | grep -v "-----" | tr -d '\n'
RSA_PRIVATE_KEY=
RSA_PUBLIC_KEY=

# Token 密钥（JWT 签名）
TOKEN_SECRET=your-token-secret
