  "key_decisions": [
    {
      "decision": "借鉴 claw-code 的 PermissionPolicy 设计工具权限系统",
      "reason": "claw-code 的权限系统设计精良，4 级权限控制可以防止工具越权执行",
      "alternatives_rejected": [
        "无权限控制（安全风险）",
        "RBAC 权限（过于复杂）"
      ]
    },
    {
      "decision": "MCP 工具采用占位实现，不实现完整协议",
      "reason": "MCP 协议复杂度高，毕业设计时间有限，先搭建框架后续扩展",
      "alternatives_rejected": [
        "完整实现 MCP 协议（工作量过大）",
        "不支持 MCP（与设计文档不符）"
      ]
    },
    {
      "decision": "Web 搜索使用 DuckDuckGo API",
      "reason": "DuckDuckGo API 免费无需 API Key，适合毕业设计",
      "alternatives_rejected": [
        "Google Search API（需要付费）",
        "Bing Search API（需要 API Key）"
      ]
    }
  ],
